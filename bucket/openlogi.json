{
    "version": "0.6.22",
    "description": "⚡️A native, local-first alternative to Logitech Options+, written in Rust 🦀 — remap buttons, DPI, and SmartShift over HID++. No account, no telemetry.",
    "homepage": "https://openlogi.org/",
    "license": {
        "identifier": "MIT",
        "url": "https://github.com/AprilNEA/OpenLogi?tab=MIT-2-ov-file"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/AprilNEA/OpenLogi/releases/download/v0.6.22/OpenLogi-v0.6.22-windows-x86_64.zip",
            "hash": "e8620acddce2807ebd1c0edc060a9c303363d085327b0cdf9f7bcfbf1cf8d6d4"
        },
        "arm64": {
            "url": "https://github.com/AprilNEA/OpenLogi/releases/download/v0.6.22/OpenLogi-v0.6.22-windows-arm64.zip",
            "hash": "5effd58dab53fa2bcc594ca038a78d0cbba4a9a10e60862197747d483db81e66"
        }
    },
    "installer": {
        "script": [
            "# handle runtime cache",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:USERPROFILE\\.local\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:USERPROFILE\\.local\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "bin": "OpenLogi.exe",
    "shortcuts": [
        [
            "OpenLogi.exe",
            "OpenLogi"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/AprilNEA/OpenLogi/releases",
        "jp": "$[0].tag_name",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/AprilNEA/OpenLogi/releases/download/v$version/OpenLogi-v$version-windows-x86_64.zip"
            },
            "arm64": {
                "url": "https://github.com/AprilNEA/OpenLogi/releases/download/v$version/OpenLogi-v$version-windows-arm64.zip"
            }
        }
    }
}
